IK_Status add_i64(int64_t a, int64_t b, int64_t* ik_return) {
  int64_t ik_tmp0;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
  }

  if (__builtin_add_overflow(a, b, &ik_tmp0)) {
    return IK_ERR_OVERFLOW;
  }
  *ik_return = ik_tmp0;
  return IK_OK;
}

IK_Status mul_i64(int64_t a, int64_t b, int64_t* ik_return) {
  int64_t ik_tmp0;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
