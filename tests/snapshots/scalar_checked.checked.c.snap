#include "scalar_checked.h"

CK_Status add_i64(int64_t a, int64_t b, int64_t* ck_return) {
  int64_t ik_tmp0;

  if (ck_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  if (__builtin_add_overflow(a, b, &ik_tmp0)) {
    return CK_ERR_OVERFLOW;
  }
  *ck_return = ik_tmp0;
  return CK_OK;
}

CK_Status mul_i64(int64_t a, int64_t b, int64_t* ck_return) {
  int64_t ik_tmp0;

  if (ck_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  if (__builtin_mul_overflow(a, b, &ik_tmp0)) {
    return CK_ERR_OVERFLOW;
  }
  *ck_return = ik_tmp0;
