IK_Status div_i64(int64_t a, int64_t b, int64_t* ik_return) {
  int64_t ik_tmp0;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
  }

  if (b == 0) {
    return IK_ERR_DIV_BY_ZERO;
  }
  if (a == INT64_MIN && b == -1) {
    return IK_ERR_OVERFLOW;
  }
  ik_tmp0 = a / b;
  *ik_return = ik_tmp0;
  return IK_OK;
}

IK_Status neg_i64(int64_t a, int64_t* ik_return) {
  int64_t ik_tmp0;

