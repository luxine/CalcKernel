CK_Status div_i64(int64_t a, int64_t b, int64_t* ck_return) {
  int64_t ik_tmp0;

  if (ck_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  if (b == 0) {
    return CK_ERR_DIV_BY_ZERO;
  }
  if (a == INT64_MIN && b == -1) {
    return CK_ERR_OVERFLOW;
  }
  ik_tmp0 = a / b;
  *ck_return = ik_tmp0;
  return CK_OK;
}

CK_Status neg_i64(int64_t a, int64_t* ck_return) {
  int64_t ik_tmp0;

  if (ck_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  if (a == INT64_MIN) {
    return CK_ERR_OVERFLOW;
  }
  ik_tmp0 = -a;
  *ck_return = ik_tmp0;
