CK_Status less_i64(int64_t a, int64_t b, bool* ck_return) {
  bool ik_tmp0;

  if (ck_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  ik_tmp0 = a < b;
  *ck_return = ik_tmp0;
