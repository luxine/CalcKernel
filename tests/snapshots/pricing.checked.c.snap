#include "pricing.h"

CK_Status calc_items(Item* items, int32_t len, int64_t* out, int32_t* ik_return) {
  int32_t i;
  int64_t subtotal;
  int64_t after_discount;
  int64_t tax;
  int32_t ik_tmp0;
  bool ik_tmp1;
  int64_t ik_tmp2;
  int64_t ik_tmp3;
  int64_t ik_tmp4;
  int64_t ik_tmp5;
  int64_t ik_tmp6;
  int64_t ik_tmp7;
  int64_t ik_tmp8;
  int64_t ik_tmp9;
  int64_t ik_tmp10;
  int64_t ik_tmp11;
  int32_t ik_tmp12;
  int32_t ik_tmp13;
  int32_t ik_tmp14;

  if (ik_return == NULL) {
    return CK_ERR_NULL_POINTER;
  }

  ik_tmp0 = 0;
  i = ik_tmp0;
  goto bb1;

bb1:
  ik_tmp1 = i < len;
  if (ik_tmp1) {
    goto bb2;
  } else {
    goto bb3;
  }

bb2:
  ik_tmp2 = items[i].price;
  ik_tmp3 = items[i].qty;
  if (__builtin_mul_overflow(ik_tmp2, ik_tmp3, &ik_tmp4)) {
    return CK_ERR_OVERFLOW;
  }
  subtotal = ik_tmp4;
  ik_tmp5 = items[i].discount;
  if (__builtin_sub_overflow(subtotal, ik_tmp5, &ik_tmp6)) {
    return CK_ERR_OVERFLOW;
  }
  after_discount = ik_tmp6;
  ik_tmp7 = items[i].tax_rate_ppm;
  if (__builtin_mul_overflow(after_discount, ik_tmp7, &ik_tmp8)) {
    return CK_ERR_OVERFLOW;
  }
  ik_tmp9 = 1000000;
  if (ik_tmp9 == 0) {
    return CK_ERR_DIV_BY_ZERO;
  }
  if (ik_tmp8 == INT64_MIN && ik_tmp9 == -1) {
    return CK_ERR_OVERFLOW;
  }
  ik_tmp10 = ik_tmp8 / ik_tmp9;
  tax = ik_tmp10;
  if (__builtin_add_overflow(after_discount, tax, &ik_tmp11)) {
    return CK_ERR_OVERFLOW;
  }
  out[i] = ik_tmp11;
  ik_tmp12 = 1;
  if (__builtin_add_overflow(i, ik_tmp12, &ik_tmp13)) {
    return CK_ERR_OVERFLOW;
  }
  i = ik_tmp13;
  goto bb1;

bb3:
  ik_tmp14 = 0;
  *ik_return = ik_tmp14;
  return CK_OK;
}
