(module
  (memory (export "memory") 1)
  (global (export "__ck_heap_base") i32 (i32.const 0))

  (func $calc_items (export "calc_items")
    (param $items i32)
    (param $len i32)
    (param $out i32)
    (result i32)
    (local $i i32)
    (local $subtotal i64)
    (local $after_discount i64)
    (local $tax i64)
    (local $t0 i32)
    (local $t9 i64)
    (local $t12 i32)
    (local $t1 i32)
    (local $addr0 i32)
    (local $t2 i64)
    (local $t3 i64)
    (local $t4 i64)
    (local $t5 i64)
    (local $t6 i64)
    (local $t7 i64)
    (local $t8 i64)
    (local $t10 i64)
    (local $t11 i64)
    (local $addr1 i32)
    (local $t13 i32)
    (local $t14 i32)
    i32.const 0
    local.set $t0
    local.get $t0
    local.set $i
    i64.const 1000000
    local.set $t9
    i32.const 1
    local.set $t12
    block $ik_exit
      loop $ik_loop
        local.get $i
        local.get $len
        i32.lt_s
        local.set $t1
        local.get $t1
        i32.eqz
        br_if $ik_exit
        local.get $items
        local.get $i
        i32.const 32
        i32.mul
        i32.add
        local.set $addr0
        local.get $addr0
        i64.load offset=0 align=8
        local.set $t2
        local.get $addr0
        i32.const 8
        i32.add
        i64.load offset=0 align=8
        local.set $t3
        local.get $t2
        local.get $t3
        i64.mul
        local.set $t4
        local.get $t4
        local.set $subtotal
        local.get $addr0
        i32.const 16
        i32.add
        i64.load offset=0 align=8
        local.set $t5
        local.get $subtotal
        local.get $t5
        i64.sub
        local.set $t6
        local.get $t6
        local.set $after_discount
        local.get $addr0
        i32.const 24
        i32.add
        i64.load offset=0 align=8
        local.set $t7
        local.get $after_discount
        local.get $t7
        i64.mul
        local.set $t8
        local.get $t8
        local.get $t9
        i64.div_s
        local.set $t10
        local.get $t10
        local.set $tax
        local.get $after_discount
        local.get $tax
        i64.add
        local.set $t11
        local.get $out
        local.get $i
        i32.const 8
        i32.mul
        i32.add
        local.set $addr1
        local.get $addr1
        local.get $t11
        i64.store offset=0 align=8
        local.get $i
        local.get $t12
        i32.add
        local.set $t13
        local.get $t13
        local.set $i
        br $ik_loop
      end
    end
    i32.const 0
    local.set $t14
    local.get $t14
    return
  )
)
