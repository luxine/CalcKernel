#include "scalar_control_checked.h"

IK_Status sum_to_n(int64_t n, int64_t* ik_return) {
  int64_t i;
  int64_t sum;
  int64_t ik_tmp0;
  int64_t ik_tmp1;
  bool ik_tmp2;
  int64_t ik_tmp3;
  int64_t ik_tmp4;
  int64_t ik_tmp5;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
  }

  ik_tmp0 = 0;
  i = ik_tmp0;
  ik_tmp1 = 0;
  sum = ik_tmp1;
  goto bb1;

bb1:
  ik_tmp2 = i < n;
  if (ik_tmp2) {
    goto bb2;
  } else {
    goto bb3;
  }

bb2:
  if (__builtin_add_overflow(sum, i, &ik_tmp3)) {
    return IK_ERR_OVERFLOW;
  }
  sum = ik_tmp3;
  ik_tmp4 = 1;
  if (__builtin_add_overflow(i, ik_tmp4, &ik_tmp5)) {
    return IK_ERR_OVERFLOW;
  }
  i = ik_tmp5;
  goto bb1;

bb3:
  *ik_return = sum;
  return IK_OK;
}

IK_Status choose(int64_t a, int64_t b, int64_t* ik_return) {
  bool ik_tmp0;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
  }

  ik_tmp0 = a > b;
  if (ik_tmp0) {
    goto bb1;
  } else {
    goto bb2;
  }

bb1:
  *ik_return = a;
  return IK_OK;

bb2:
  *ik_return = b;
  return IK_OK;
}

IK_Status condition_overflow(int64_t a, int64_t b, int64_t* ik_return) {
  int64_t ik_tmp0;
  int64_t ik_tmp1;
  bool ik_tmp2;
  int64_t ik_tmp3;
  int64_t ik_tmp4;

  if (ik_return == NULL) {
    return IK_ERR_NULL_POINTER;
  }

  if (__builtin_add_overflow(a, b, &ik_tmp0)) {
    return IK_ERR_OVERFLOW;
  }
  ik_tmp1 = 0;
  ik_tmp2 = ik_tmp0 > ik_tmp1;
  if (ik_tmp2) {
    goto bb1;
  } else {
    goto bb2;
  }

bb1:
  ik_tmp3 = 1;
  *ik_return = ik_tmp3;
  return IK_OK;

bb2:
  ik_tmp4 = 0;
  *ik_return = ik_tmp4;
  return IK_OK;
}
