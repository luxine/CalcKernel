(module
  (memory (export "memory") 1)
  (global (export "__ck_heap_base") i32 (i32.const 0))

  (func $first_price (export "first_price")
    (param $items i32)
    (result i64)
    (local $t0 i32)
    (local $t1 i64)
    i32.const 0
    local.set $t0
    local.get $items
    local.get $t0
    i32.const 32
    i32.mul
    i32.add
    i64.load offset=0 align=8
    local.set $t1
    local.get $t1
    return
  )

  (func $get_price (export "get_price")
    (param $items i32)
    (param $i i32)
    (result i64)
    (local $t0 i64)
    local.get $items
    local.get $i
    i32.const 32
    i32.mul
    i32.add
    i64.load offset=0 align=8
    local.set $t0
    local.get $t0
    return
  )

  (func $write_i64 (export "write_i64")
    (param $out i32)
    (param $value i64)
    (result i32)
    (local $t0 i32)
    (local $t1 i32)
    i32.const 0
    local.set $t0
    local.get $out
    local.get $t0
    i32.const 8
    i32.mul
    i32.add
    local.get $value
    i64.store offset=0 align=8
    i32.const 0
    local.set $t1
    local.get $t1
    return
  )
)
