#pragma once

#include <stdint.h>
#include <stdbool.h>
#include <stddef.h>

#if defined(_WIN32) || defined(__CYGWIN__)
  #ifdef CK_BUILD_DLL
    #define CK_API __declspec(dllexport)
  #else
    #define CK_API __declspec(dllimport)
  #endif
#else
  #define CK_API __attribute__((visibility("default")))
#endif

typedef int32_t CK_Status;

#define CK_OK ((CK_Status)0)
#define CK_ERR_OVERFLOW ((CK_Status)1)
#define CK_ERR_DIV_BY_ZERO ((CK_Status)2)
#define CK_ERR_NULL_POINTER ((CK_Status)3)

#ifdef __cplusplus
extern "C" {
#endif

CK_API CK_Status calc(int64_t a, int64_t b, int64_t* ik_return);

CK_API CK_Status calc_overflow(int64_t a, int64_t b, int64_t* ik_return);

#ifdef __cplusplus
}
#endif
