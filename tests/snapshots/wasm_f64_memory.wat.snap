(module
  (memory (export "memory") 1)

  (func $write_scale (export "write_scale")
    (param $values i32)
    (param $i i32)
    (param $factor f64)
    (result f64)
    (local $t0 f64)
    (local $t1 f64)
    (local $t2 f64)
    local.get $values
    local.get $i
    i32.const 8
    i32.mul
    i32.add
    f64.load offset=0 align=8
    local.set $t0
    local.get $t0
    local.get $factor
    f64.mul
    local.set $t1
    local.get $values
    local.get $i
    i32.const 8
    i32.mul
    i32.add
    local.get $t1
    f64.store offset=0 align=8
    local.get $values
    local.get $i
    i32.const 8
    i32.mul
    i32.add
    f64.load offset=0 align=8
    local.set $t2
    local.get $t2
    return
  )

  (func $quote_total (export "quote_total")
    (param $quotes i32)
    (param $i i32)
    (result f64)
    (local $t0 f64)
    (local $t1 f64)
    (local $t2 f64)
    local.get $quotes
    local.get $i
    i32.const 16
    i32.mul
    i32.add
    f64.load offset=0 align=8
    local.set $t0
    local.get $quotes
    local.get $i
    i32.const 16
    i32.mul
    i32.add
    i32.const 8
    i32.add
    f64.load offset=0 align=8
    local.set $t1
    local.get $t0
    local.get $t1
    f64.add
    local.set $t2
    local.get $t2
    return
  )
)
