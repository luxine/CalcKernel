(module
  (memory (export "memory") 1)
  (global (export "__ck_heap_base") i32 (i32.const 0))

  (func $max_i32 (export "max_i32")
    (param $a i32)
    (param $b i32)
    (result i32)
    (local $t0 i32)
    (local $ik_bb i32)
    (local $ik_ret i32)
    i32.const 0
    local.set $ik_bb
    block $ik_exit
      loop $ik_dispatch
        block $ik_case0
          block $ik_case1
            block $ik_case2
              local.get $ik_bb
              br_table $ik_case0 $ik_case1 $ik_case2 $ik_case0
            end
            local.get $b
            local.set $ik_ret
            br $ik_exit
          end
          local.get $a
          local.set $ik_ret
          br $ik_exit
        end
        local.get $a
        local.get $b
        i32.gt_s
        local.set $t0
        local.get $t0
        if
          i32.const 1
          local.set $ik_bb
        else
          i32.const 2
          local.set $ik_bb
        end
        br $ik_dispatch
      end
    end
    local.get $ik_ret
  )

  (func $sum_to_n (export "sum_to_n")
    (param $n i64)
    (result i64)
    (local $i i64)
    (local $sum i64)
    (local $t0 i64)
    (local $t1 i64)
    (local $t2 i32)
    (local $t3 i64)
    (local $t4 i64)
    (local $t5 i64)
    (local $ik_bb i32)
    (local $ik_ret i64)
    i32.const 0
    local.set $ik_bb
    block $ik_exit
      loop $ik_dispatch
        block $ik_case0
          block $ik_case1
            block $ik_case2
              block $ik_case3
                local.get $ik_bb
                br_table $ik_case0 $ik_case1 $ik_case2 $ik_case3 $ik_case0
              end
              local.get $sum
              local.set $ik_ret
              br $ik_exit
            end
            local.get $sum
            local.get $i
            i64.add
            local.set $t3
            local.get $t3
            local.set $sum
            i64.const 1
            local.set $t4
            local.get $i
            local.get $t4
            i64.add
            local.set $t5
            local.get $t5
            local.set $i
            i32.const 1
            local.set $ik_bb
            br $ik_dispatch
          end
          local.get $i
          local.get $n
          i64.lt_s
          local.set $t2
          local.get $t2
          if
            i32.const 2
            local.set $ik_bb
          else
            i32.const 3
            local.set $ik_bb
          end
          br $ik_dispatch
        end
        i64.const 0
        local.set $t0
        local.get $t0
        local.set $i
        i64.const 0
        local.set $t1
        local.get $t1
        local.set $sum
        i32.const 1
        local.set $ik_bb
        br $ik_dispatch
      end
    end
    local.get $ik_ret
  )
)
