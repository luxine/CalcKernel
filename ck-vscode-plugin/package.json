{
  "name": "ck-vscode-plugin",
  "displayName": "CalcKernel",
  "description": "VSCode language support for CalcKernel .ck files.",
  "version": "0.1.0",
  "publisher": "luxine",
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:calckernel"],
  "main": "./dist/extension.cjs",
  "contributes": {
    "languages": [
      {
        "id": "calckernel",
        "aliases": ["CalcKernel", "ck"],
        "extensions": [".ck"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "calckernel",
        "scopeName": "source.calckernel",
        "path": "./syntaxes/calckernel.tmLanguage.json"
      }
    ],
    "snippets": [
      { "language": "calckernel", "path": "./snippets/calckernel.json" }
    ]
  },
  "scripts": {
    "precompile": "npm --prefix .. run build",
    "compile": "npm run precompile && tsc -p . --noEmit && node esbuild.mjs",
    "watch": "tsc -p . --noEmit --watch",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "calckernel": "file:..",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
