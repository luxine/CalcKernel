{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CalcKernel",
  "scopeName": "source.calckernel",
  "patterns": [
    { "include": "#comments" },
    { "include": "#functionDeclarations" },
    { "include": "#structDeclarations" },
    { "include": "#localVariableDeclarations" },
    { "include": "#fieldDeclarations" },
    { "include": "#parameters" },
    { "include": "#memberAccess" },
    { "include": "#builtinFunctions" },
    { "include": "#functionCalls" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#typeReferences" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#variableReferences" }
  ],
  "repository": {
    "comments": { "patterns": [{ "name": "comment.line.double-slash.calckernel", "match": "//.*$" }] },
    "functionDeclarations": {
      "patterns": [{
        "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": { "name": "keyword.declaration.function.calckernel" },
          "2": { "name": "entity.name.function.calckernel" }
        }
      }]
    },
    "structDeclarations": {
      "patterns": [{
        "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": { "name": "keyword.declaration.struct.calckernel" },
          "2": { "name": "entity.name.type.struct.calckernel" }
        }
      }]
    },
    "localVariableDeclarations": {
      "patterns": [{
        "match": "\\b(let)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
        "captures": {
          "1": { "name": "keyword.declaration.calckernel" },
          "2": { "name": "variable.other.definition.local.calckernel" }
        }
      }]
    },
    "fieldDeclarations": {
      "patterns": [{
        "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
        "captures": {
          "1": { "name": "variable.other.member.definition.calckernel" }
        }
      }]
    },
    "parameters": {
      "patterns": [{
        "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:\\s*(?:ptr\\b|i32\\b|i64\\b|u32\\b|u64\\b|f64\\b|bool\\b))",
        "captures": {
          "1": { "name": "variable.parameter.calckernel" }
        }
      }]
    },
    "memberAccess": {
      "patterns": [{
        "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": { "name": "punctuation.accessor.calckernel" },
          "2": { "name": "variable.other.member.access.calckernel" }
        }
      }]
    },
    "builtinFunctions": {
      "patterns": [{
        "name": "support.function.builtin.calckernel",
        "match": "\\b(?:i32_to_f64|u32_to_f64)\\b"
      }]
    },
    "functionCalls": {
      "patterns": [{
        "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
        "captures": {
          "1": { "name": "entity.name.function.call.calckernel" }
        }
      }]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.calckernel", "match": "\\b(?:if|else|while|return)\\b" },
        { "name": "keyword.declaration.calckernel", "match": "\\b(?:export|fn|let|struct)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.primitive.calckernel", "match": "\\b(?:i32|i64|u32|u64|f64|bool)\\b" },
        { "name": "storage.type.pointer.calckernel", "match": "\\bptr\\b" }
      ]
    },
    "typeReferences": {
      "patterns": [{ "name": "entity.name.type.calckernel", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }]
    },
    "booleans": { "patterns": [{ "name": "constant.language.boolean.calckernel", "match": "\\b(?:true|false)\\b" }] },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.calckernel", "match": "\\b[0-9]+(?:\\.[0-9]+|[eE][+-]?[0-9]+|\\.[0-9]+[eE][+-]?[0-9]+)\\b" },
        { "name": "constant.numeric.integer.calckernel", "match": "\\b[0-9]+\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.calckernel", "match": "==|!=|<=|>=|&&|\\|\\||[+\\-*/%<>=!]" },
        { "name": "punctuation.separator.calckernel", "match": "[;:,]" },
        { "name": "punctuation.bracket.calckernel", "match": "[{}\\[\\]()]" }
      ]
    },
    "variableReferences": {
      "patterns": [{
        "name": "variable.other.readwrite.calckernel",
        "match": "\\b(?!if\\b|else\\b|while\\b|return\\b|export\\b|fn\\b|let\\b|struct\\b|i32\\b|i64\\b|u32\\b|u64\\b|f64\\b|bool\\b|ptr\\b|true\\b|false\\b)[a-z_][A-Za-z0-9_]*\\b"
      }]
    }
  }
}
