{
  "name": "intkernel",
  "version": "0.3.0",
  "description": "A small integer-only DSL compiler that emits readable C.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "ikc": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "docs",
    "examples",
    "bench",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ikc": "node dist/src/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "compiler",
    "dsl",
    "c"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "wabt": "^1.0.39"
  }
}
